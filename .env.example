# API Configuration
API_BASE_URL=https://api.shgcustomer.com/api
API_TIMEOUT=30

# Firebase Configuration
FIREBASE_PROJECT_ID=shg-customer-app
FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY

# App Version
APP_VERSION=1.0.0
BUILD_NUMBER=1

# Environment
ENVIRONMENT=development
DEBUG_MODE=true

# Feature Flags
ENABLE_NOTIFICATIONS=true
ENABLE_OFFLINE_MODE=true
ENABLE_DARK_MODE=false
