# EditorConfig is awesome: https://EditorConfig.org

root = true

[*]
indent_style = space
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.dart]
indent_size = 2
max_line_length = 100

[*.{json,yaml,yml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
insert_final_newline = false

[*.{js,jsx,ts,tsx}]
indent_size = 2
